{
  "name": "dcc-support",
  "private": true,
  "workspaces": ["packages/*"],
  "catalog": {
    "vitest": "^4.0.18",
    "typescript": "^5.8.0",
    "@biomejs/biome": "^2.4.5",
    "sharp": "^0.34.5",
    "screenshot-desktop": "^1.15.3",
    "zod": "^3.25.0",
    "hono": "^4.7.0",
    "@trpc/server": "^11.1.0",
    "@trpc/client": "^11.13.4",
    "@trpc/react-query": "^11.13.4"
  },
  "scripts": {
    "start": "bun run packages/cli/src/index.ts",
    "dev": "echo '\n  ➜  Client: http://localhost:5173/\n' && bun run --filter '@dcc/server' --elide-lines=0 dev & bun run --filter '@dcc/client' --elide-lines=0 dev & wait",
    "dev:cli": "bun --watch run packages/cli/src/index.ts",
    "start:web": "bun run packages/server/src/index.ts",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run && bun test packages/server/test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "tsc -b && biome ci .",
    "verify": "bun run packages/core/src/verify/run-all.ts",
    "verify:streaming": "bun run packages/core/src/verify/verify-streaming.ts",
    "verify:image": "bun run packages/core/src/verify/verify-image.ts",
    "verify:session": "bun run packages/core/src/verify/verify-session.ts",
    "verify:agents": "bun run packages/core/src/verify/verify-agents.ts",
    "verify:prompt": "bun run packages/core/src/verify/verify-system-prompt.ts",
    "verify:capture-diff": "bun run packages/core/src/verify/verify-capture-diff.ts",
    "verify:coach-loop": "bun run packages/core/src/verify/verify-coach-loop.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "screenshot-desktop": "catalog:",
    "sharp": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

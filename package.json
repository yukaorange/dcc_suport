{
  "name": "dcc-support",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "check": "bun run typecheck && biome ci .",
    "verify": "bun run src/verify/run-all.ts",
    "verify:streaming": "bun run src/verify/verify-streaming.ts",
    "verify:image": "bun run src/verify/verify-image.ts",
    "verify:session": "bun run src/verify/verify-session.ts",
    "verify:agents": "bun run src/verify/verify-agents.ts",
    "verify:prompt": "bun run src/verify/verify-system-prompt.ts",
    "verify:capture-diff": "bun run src/verify/verify-capture-diff.ts",
    "verify:coach-loop": "bun run src/verify/verify-coach-loop.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "pixelmatch": "^7.0.0",
    "screenshot-desktop": "^1.15.3",
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "latest",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  }
}

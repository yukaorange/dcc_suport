{
  "name": "dcc-support",
  "private": true,
  "workspaces": ["packages/*"],
  "catalog": {
    "vitest": "^4.0.18",
    "typescript": "^5.8.0",
    "@biomejs/biome": "^2.4.5",
    "sharp": "^0.34.5",
    "screenshot-desktop": "^1.15.3"
  },
  "scripts": {
    "start": "bun run packages/cli/src/index.ts",
    "dev": "bun --watch run packages/cli/src/index.ts",
    "start:web": "echo 'Not implemented yet. See Step 2 in .work/plan-DCC-8.md' && exit 1",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "check": "tsc -b && biome ci .",
    "verify": "bun run packages/core/src/verify/run-all.ts",
    "verify:streaming": "bun run packages/core/src/verify/verify-streaming.ts",
    "verify:image": "bun run packages/core/src/verify/verify-image.ts",
    "verify:session": "bun run packages/core/src/verify/verify-session.ts",
    "verify:agents": "bun run packages/core/src/verify/verify-agents.ts",
    "verify:prompt": "bun run packages/core/src/verify/verify-system-prompt.ts",
    "verify:capture-diff": "bun run packages/core/src/verify/verify-capture-diff.ts",
    "verify:coach-loop": "bun run packages/core/src/verify/verify-coach-loop.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "latest",
    "screenshot-desktop": "catalog:",
    "sharp": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
